def manual_input(page, check):

    list_names = []
    page.clean()

    def field():
        global Black_list, white_list
        def trigger_main():

            main(page)
        process = normalize(text.value)
        for proc in psutil.process_iter(['name']):
            list_names.append(normalize(proc.info['name']))
        if check == "B":
            checker = process + " " in Black_list
        else:
            checker = process + " " in white_list
        page.clean()
        if process not in list_names or checker:
            page.add(ft.Text(
                "Процесс не найден или уже ограничен. Проверьте, запущено ли приложение и повторите попытку. Если не помогло, убедитесь в правильности написания."),
                     ft.Button("Вернуться в главное", on_click = trigger_main))
            page.update()
            return False
        else:
            def adding(check):
                page.clean()
                if check == "B":
                    global Black_list
                    Black_list.append(normalize(process) + " ")
                    page.add(ft.Text("Процесс успешно добавлен!"),
                             ft.Button("Вернуться в главное", on_click=trigger_main))
                else:
                    global white_list
                    white_list.append(normalize(process) + " ")
                    page.add(ft.Text("Процесс успешно добавлен!"),
                             ft.Button("Вернуться в главное", on_click = trigger_main))
            def add_tr():
                adding(check)
            page.add(ft.Text("Процесс найден!"), ft.Text(normalize(process)), ft.Button("Вернуться в главное", on_click = trigger_main),
                     ft.Button("Добавить в список", on_click = add_tr))
            page.update()

    text = ft.TextField(label="Желаемый процесс")
    page.add(text, ft.Button("Подтвердить", on_click=field))


def see_the_list(page):

    page.clean()
    cl = ft.Column(
        spacing=2,
        height=650,
        width=500,
        scroll=ft.ScrollMode.ALWAYS
    )
    count = 0
    inner_list = []
    for proc in psutil.process_iter(['name']):

        if 'user' in proc.username().split('\\') and normalize(proc.name()) not in inner_list:
            count += 1
            inner_list.append(normalize(proc.name()))
            cl.controls.append(ft.Text(str(count) + ". " + normalize(proc.name())))
    page.add(ft.Container(cl, border=ft.Border.all(1)))
    page.add(ft.Button("Вернуться в главное", on_click=main))
    page.update()
